<h2>Add Contact</h2>

<form method="post" action="/contact/add">

    ID: <input type="number" name="ContactId" /><br /><br />
    First Name: <input type="text" name="FirstName" /><br /><br />
    Last Name: <input type="text" name="LastName" /><br /><br />
    Company: <input type="text" name="CompanyName" /><br /><br />
    Email: <input type="email" name="EmailId" /><br /><br />
    Mobile: <input type="number" name="MobileNo" /><br /><br />
    Designation: <input type="text" name="Designation" /><br /><br />

    <button type="submit">Add</button>

</form>
