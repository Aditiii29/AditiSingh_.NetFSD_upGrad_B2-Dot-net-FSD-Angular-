@model List<ContactManagementWebApplication.Models.ContactInfo>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <div class="card-header d-flex justify-content-between py-3">
        <h4 class="mb-0">All Contacts</h4>
        <a href="/Contact/AddContact" class="btn btn-light btn-sm">+ Add Contact</a>
    </div>
    <div class="card-body">
        <form action="/Contact/GetContactById" method="get" class="d-flex gap-2 mb-3">
            <input type="number" name="id" class="form-control w-auto" placeholder="Search by ID..." required />
            <button class="btn btn-primary">Search</button>
        </form>

        @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info">No contacts found.</div>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr><th>ID</th><th>First Name</th><th>Last Name</th><th>Company</th><th>Email</th><th>Mobile</th><th>Designation</th></tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.ContactId</td>
                            <td>@c.FirstName</td>
                            <td>@c.LastName</td>
                            <td>@c.CompanyName</td>
                            <td>@c.EmailId</td>
                            <td>@c.MobileNo</td>
                            <td>@c.Designation</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>