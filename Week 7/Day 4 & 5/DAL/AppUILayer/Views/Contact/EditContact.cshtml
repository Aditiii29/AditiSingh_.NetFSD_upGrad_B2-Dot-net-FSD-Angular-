@model DAL.Model.ContactInfo
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Add Contact";
}

<div class="container mt-4">
    <h2>✏️ Edit Contact</h2>
    <hr />

    <form asp-controller="Contact" asp-action="EditContact" method="post">

        @* Hidden field - sends ContactId back on POST *@
        <input type="hidden" asp-for="ContactId" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="EmailId" class="form-label"></label>
                <input asp-for="EmailId" class="form-control" />
                <span asp-validation-for="EmailId" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="MobileNo" class="form-label"></label>
                <input asp-for="MobileNo" class="form-control" />
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Designation" class="form-label"></label>
            <input asp-for="Designation" class="form-control" />
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Company</label>
                <select asp-for="CompanyId"
                        asp-items="ViewBag.Companies"
                        class="form-select"></select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Department</label>
                <select asp-for="DepartmentId"
                        asp-items="ViewBag.Departments"
                        class="form-select"></select>
            </div>
        </div>
        <button type="submit" class="btn btn-warning">Update Contact</button>
        <a asp-controller="Contact" asp-action="ShowContacts"
           class="btn btn-secondary">Cancel</a>
    </form>
</div>