@model DAL.Model.ContactInfo
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Add Contact";
}

<div class="container mt-4">
    <h2>👤 Contact Details</h2>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">Full Name</dt>
        <dd class="col-sm-9">@Model.FirstName @Model.LastName</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.EmailId</dd>

        <dt class="col-sm-3">Mobile</dt>
        <dd class="col-sm-9">@Model.MobileNo</dd>

        <dt class="col-sm-3">Designation</dt>
        <dd class="col-sm-9">@Model.Designation</dd>

        <dt class="col-sm-3">Company</dt>
        <dd class="col-sm-9">@Model.CompanyData?.CompanyName</dd>

        <dt class="col-sm-3">Department</dt>
        <dd class="col-sm-9">@Model.DepartmentData?.DepartmentName</dd>
    </dl>

    <a asp-controller="Contact"
       asp-action="EditContact"
       asp-route-id="@Model.ContactId"
       class="btn btn-warning">Edit</a>

    <a asp-controller="Contact"
       asp-action="ShowContacts"
       class="btn btn-secondary">Back to List</a>
</div>